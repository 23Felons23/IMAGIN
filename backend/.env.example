# Podcast Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# HuggingFace token for pyannote speaker diarization
# Get one at: https://hf.co/settings/tokens
# Then accept the license at: https://hf.co/pyannote/speaker-diarization
HF_TOKEN=your_token_here

# LLM Provider: openai | anthropic | ollama (default: openai)
LLM_PROVIDER=openai

# OpenAI API key (required when LLM_PROVIDER=openai)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Anthropic API key (required when LLM_PROVIDER=anthropic)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Ollama base URL (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
